# Copy this file to backend/.env. Never expose these values through VITE_*.

PORT=8000
DATABASE_URL=postgresql://dormitory:dormitory@127.0.0.1:5432/dormitory
CORS_ORIGINS=http://localhost:5173
DEMO_MODE=true

# Set a stable, randomly generated secret outside throwaway demo runs.
JWT_SECRET=
JWT_EXPIRES_SECONDS=86400
COOKIE_SECURE=false

# Optional. Empty uses the deterministic policy fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_SECONDS=8

SOLVER_WORKER_URL=http://127.0.0.1:8010
SOLVER_TIME_LIMIT_SECONDS=2
WAIT_SECONDS=120
COUNTDOWN_SECONDS=5
MOCK_GPS_INTERVAL_MS=1000
